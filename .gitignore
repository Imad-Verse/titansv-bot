# ==============================================================================
#                 Professional GitIgnore for TitanSV Bot
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Environments & Sensitive Configs (CRITICAL Security)
# ------------------------------------------------------------------------------
.env
.env.*
*.env
*.env.json
env.bak/
venv.bak/
instance/
config/config.json
secrets/

# ------------------------------------------------------------------------------
# 2. Cookies & Sessions (CRITICAL Security)
# ------------------------------------------------------------------------------
# Ignore all cookie configuration text files to protect active sessions
cookies/*.txt
cookies/**/*.txt

# Allow only the extraction script to be committed
!cookies/extract_cookies.py

# ------------------------------------------------------------------------------
# 3. Database & Local Storage
# ------------------------------------------------------------------------------
# Ignore SQLite/local databases to prevent exposing user data/activity
data/*.db
data/**/*.db
data/*.sqlite
data/*.sqlite3
data/*.db-journal

# Ignore local database backups
data/backups/

# Ignore proxy lists (can contain authenticated proxies)
data/proxies.txt

# ------------------------------------------------------------------------------
# 4. Downloads, Logs & Temporary Files
# ------------------------------------------------------------------------------
downloads/
logs/
.titan_runtime/
tmp_replace.py
*.tmp
*.log

# ------------------------------------------------------------------------------
# 5. Python Compilation & Cache Files
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
.nox/
build/
dist/
*.egg-info/
.eggs/

# ------------------------------------------------------------------------------
# 6. Virtual Environments
# ------------------------------------------------------------------------------
venv/
.venv/
env/
ENV/

# ------------------------------------------------------------------------------
# 7. OS & IDE System Configuration
# ------------------------------------------------------------------------------
# Windows
desktop.ini
Thumbs.db

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE / Editor Settings (VS Code, PyCharm, Sublime, etc.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.sublime-project
*.sublime-workspace
